# ─── Identifiants CESAL (utilisés seulement pour le login semi-manuel) ───
CESAL_EMAIL=simon5.amar@gmail.com
CESAL_PASSWORD=

# ─── Telegram ───
# 1. Parle à @BotFather sur Telegram -> /newbot -> copie le token ici
TELEGRAM_BOT_TOKEN=
# 2. Parle à @userinfobot pour obtenir ton chat id
TELEGRAM_CHAT_ID=

# ─── Comportement ───
# alert   = détecte + notifie seulement (TU réserves)   <-- défaut sûr
# reserve = détecte + réserve automatiquement           <-- à activer quand tu es prêt
MODE=alert

# Date de sortie à écrire dans le datepicker (format dd/mm/yyyy)
DATE_SORTIE=18/12/2026

# Intervalle de vérification en minutes (en mode boucle locale)
INTERVAL_MINUTES=10

# Headless: true en serveur, false pour voir le navigateur (debug / 1er login)
HEADLESS=true
